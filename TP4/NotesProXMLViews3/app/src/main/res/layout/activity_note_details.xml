<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/my_primary"
    android:padding="16dp"
    tools:context=".NoteDetailsActivity">

    <RelativeLayout
        android:id="@+id/title_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp">

        <TextView
            android:id="@+id/page_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_new_note"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/save_note_btn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/save_note"
            android:src="@drawable/ic_baseline_done_24"
            app:tint="@color/white" />

    </RelativeLayout>

    <!-- ScrollView para que quando a imagem aparece o conteúdo não fique cortado
         e o utilizador consiga fazer scroll para ver tudo -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/title_bar_layout"
        android:layout_above="@+id/delete_note_text_view_btn"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- cartão branco que contém os campos de texto e a imagem -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_corner"
                android:backgroundTint="@color/white"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- campo do título da nota -->
                <EditText
                    android:id="@+id/notes_title_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="8dp"
                    android:autofillHints="Notes Title"
                    android:hint="@string/title"
                    android:inputType="text"
                    android:padding="12dp"
                    android:textColor="@color/black"
                    android:textColorHint="#888888"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- linha separadora visual de 1dp entre título e conteúdo -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DDDDDD" />

                <!-- campo do conteúdo da nota -->
                <EditText
                    android:id="@+id/notes_content_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="8dp"
                    android:autofillHints="Notes Content"
                    android:gravity="top"
                    android:hint="@string/content"
                    android:inputType="textMultiLine"
                    android:minLines="10"
                    android:padding="12dp"
                    android:textColor="@color/black"
                    android:textColorHint="#888888"
                    android:textSize="20sp" />

                <!-- linha separadora antes da secção de imagem -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DDDDDD"
                    android:layout_marginTop="8dp"/>

                <!-- mostra a imagem escolhida pelo utilizador, começa invisível
                     e só aparece depois de o utilizador escolher uma imagem da galeria
                     ou se a nota já tiver uma imagem guardada no firebase storage -->
                <!-- fitCenter mostra a imagem inteira sem cortar, ajustando a altura ao conteúdo real -->
                <ImageView
                    android:id="@+id/note_image_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp"
                    android:scaleType="fitCenter"
                    android:adjustViewBounds="true"
                    android:background="#F0F0F0"
                    android:visibility="gone" />-

                <!-- botão para abrir a galeria -->
                <TextView
                    android:id="@+id/add_image_btn"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="+ Add Image"
                    android:textColor="@color/my_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp" />

                <!-- linha separadora antes da secção de cápsula do tempo -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DDDDDD"/>

                <!-- botão para abrir o date picker e bloquear a nota até uma data -->
                <TextView
                    android:id="@+id/lock_note_btn"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="Bloquear até uma data"
                    android:textColor="@color/my_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp" />

                <!-- mostra a data selecionada, fica escondido até o utilizador escolher uma data -->
                <TextView
                    android:id="@+id/lock_date_text_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- botão de apagar a nota, fixo no fundo do ecrã, só aparece em modo de edição -->
    <TextView
        android:id="@+id/delete_note_text_view_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="center"
        android:padding="16dp"
        android:text="@string/delete_note"
        android:textColor="#FF0000"
        android:textSize="18sp"
        android:visibility="gone" />



</RelativeLayout>